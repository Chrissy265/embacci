# EmailJS credentials for the Home page "Let's Talk" contact form.
# Sign up at https://www.emailjs.com, then copy this file to `.env` and fill in.
#
# 1. Email Services  -> create a service (Gmail, Outlook, custom SMTP) -> Service ID
# 2. Email Templates -> create a template -> Template ID
#       In the template, set the "To Email" field to:  {{to_email}}
#       (the app passes both africa@embacci.com and eastafrica@embacci.com)
#       Available template variables: {{from_name}} {{from_email}} {{reply_to}}
#       {{topic}} {{subject}} {{message}} {{to_email}}
# 3. Account -> General -> Public Key
#
# These are exposed to the browser (that's expected for EmailJS). Restrict the
# allowed domains in your EmailJS dashboard to prevent abuse.

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
